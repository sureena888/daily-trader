# ============================================================
# .env.example
# 🔒 SECRET KEYS — copy this file to ".env" and fill in values
# ============================================================
# IMPORTANT: Never share your .env file or commit it to GitHub.
# The .gitignore file already excludes it.
#
# How to get each key:
#   ANTHROPIC_API_KEY  → https://console.anthropic.com → API Keys
#   TWILIO_*           → https://console.twilio.com → Account Info
# ============================================================

# Claude AI (for generating the daily advice)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Twilio (for sending SMS notifications)
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# Phone numbers to send the daily SMS to (comma-separated)
RECIPIENT_PHONES=+1XXXXXXXXXX,+1XXXXXXXXXX
